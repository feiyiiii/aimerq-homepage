---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import FormattedDate from "../../components/FormattedDate.astro";

const posts = (await getCollection("blog")).sort(
    (a: { data: { pubDate: number } }, b: { data: { pubDate: number } }) =>
        b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const reflections = posts.filter((post: any) => post.data.category === "生活感悟");
const readingNotes = posts.filter((post: any) => post.data.category === "读书笔记");
const BLOG_EDIT_URL = "https://github.com/feiyiiii/aimerq-homepage/edit/main/src/pages/blogs/index.astro";
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body>
        <Header />
        <div
            class="min-h-screen font-mono pb-16"
            style={{
                backgroundColor: "var(--theme-background)",
                color: "var(--theme-text)",
            }}
        >
            <div class="space-y-6 max-w-screen-xl mx-auto px-4 py-8">
                <section
                    class="rounded-3xl p-6 sm:p-10 futuristic-panel"
                    style={{
                        backgroundColor: "var(--theme-welcomeBoxBg)",
                        border: "1px solid var(--theme-border)",
                    }}
                >
                    <div class="flex flex-wrap gap-2 mb-5">
                        <span class="f-chip">Writings</span>
                        <span class="f-chip">Reflections</span>
                        <span class="f-chip">Reading Notes</span>
                    </div>
                    <div class="text-xs uppercase tracking-[0.25em] mb-3" style={{ color: "var(--theme-secondary)" }}>
                        AimerQ / Archive
                    </div>
                    <h1 class="text-3xl sm:text-5xl font-semibold tracking-tight mb-4" style={{ color: "var(--theme-text)" }}>
                        随笔与笔记
                    </h1>
                    <p class="text-sm sm:text-base leading-8 max-w-3xl" style={{ color: "var(--theme-outputText)" }}>
                        这里放一些写给自己、也写给时间的文字。关于生活感悟，也关于读过之后仍然停留在心里的书。
                    </p>
                    <div class="mt-6">
                        <a
                            href={BLOG_EDIT_URL}
                            target="_blank"
                            rel="noreferrer"
                            class="inline-flex items-center rounded-full border px-4 py-2 text-sm transition-all hover:-translate-y-0.5"
                            style={{
                                color: "var(--theme-primary)",
                                borderColor: "var(--theme-primary)",
                            }}
                        >
                            编辑此页
                        </a>
                    </div>
                </section>

                <section class="space-y-4">
                    <div class="flex items-center justify-between">
                        <h2 class="text-lg sm:text-2xl font-semibold" style={{ color: "var(--theme-text)" }}>
                            生活感悟
                        </h2>
                        <span class="text-xs sm:text-sm f-chip" style={{ color: "var(--theme-secondary)" }}>
                            reflections
                        </span>
                    </div>
                    <div class="grid gap-5 sm:grid-cols-1 md:grid-cols-2 xl:grid-cols-3">
                    {
                        reflections.map((blog: any, index: number) => (
                                <div
                                    class="rounded-3xl transition-all duration-300 group futuristic-panel hover:-translate-y-1"
                                    style={{
                                        backgroundColor: "var(--theme-welcomeBoxBg)",
                                        border: "1px solid var(--theme-border)",
                                    }}
                                >
                                    <a
                                        class="block p-5 sm:p-6 transition-colors rounded-3xl h-full"
                                        href={`/blogs/${blog.id}`}
                                        style={{ color: "var(--theme-text)" }}
                                    >
                                        <div class="flex flex-col h-full">
                                            <div class="flex items-center justify-between mb-4">
                                                <span class="f-chip">essay {String(index + 1).padStart(2, "0")}</span>
                                                <span class="text-xs" style={{ color: "var(--theme-secondary)" }}>
                                                    reflection
                                                </div>
                                            <div class="flex-1">
                                                <h3 class="text-xl leading-8 font-semibold mb-3" style={{ color: "var(--theme-text)" }}>
                                                    {blog.data.title}
                                                </h3>
                                                {blog.data.description && (
                                                    <p
                                                        class="text-sm leading-7"
                                                        style={{ color: "var(--theme-outputText)" }}
                                                    >
                                                        {blog.data.description}
                                                    </p>
                                                )}
                                            </div>
                                            <div class="mt-5 flex flex-wrap items-center gap-3 text-xs">
                                                <span style={{ color: "var(--theme-secondary)" }}>
                                                    <FormattedDate date={blog.data.pubDate} />
                                                </span>
                                                <span style={{ color: "var(--theme-muted)" }}>
                                                    {blog.data.author || "AimerQ"}
                                                </span>
                                                <span style={{ color: "var(--theme-primary)" }}>
                                                    Read →
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            ))
                    }
                    </div>
                </section>

                <section class="space-y-4">
                    <div class="flex items-center justify-between">
                        <h2 class="text-lg sm:text-2xl font-semibold" style={{ color: "var(--theme-text)" }}>
                            读书笔记
                        </h2>
                        <span class="text-xs sm:text-sm f-chip" style={{ color: "var(--theme-accent)" }}>
                            reading notes
                        </span>
                    </div>
                    <div class="grid gap-5 sm:grid-cols-1 md:grid-cols-2 xl:grid-cols-3">
                    {
                        readingNotes.map((blog: any, index: number) => (
                                <div
                                    class="rounded-3xl transition-all duration-300 group futuristic-panel hover:-translate-y-1"
                                    style={{
                                        backgroundColor: "var(--theme-welcomeBoxBg)",
                                        border: "1px solid var(--theme-border)",
                                    }}
                                >
                                    <a
                                        class="block p-5 sm:p-6 transition-colors rounded-3xl h-full"
                                        href={`/blogs/${blog.id}`}
                                        style={{ color: "var(--theme-text)" }}
                                    >
                                        <div class="flex flex-col h-full">
                                            <div class="flex items-center justify-between mb-4">
                                                <span class="f-chip">book {String(index + 1).padStart(2, "0")}</span>
                                                <span class="text-xs" style={{ color: "var(--theme-accent)" }}>
                                                    notes
                                                </div>
                                            </div>
                                            <div class="flex-1">
                                                <h3 class="text-xl leading-8 font-semibold mb-3" style={{ color: "var(--theme-text)" }}>
                                                    {blog.data.title}
                                                </h3>
                                                {blog.data.description && (
                                                    <p
                                                        class="text-sm leading-7"
                                                        style={{ color: "var(--theme-outputText)" }}
                                                    >
                                                        {blog.data.description}
                                                    </p>
                                                )}
                                            </div>
                                            <div class="mt-5 flex flex-wrap items-center gap-3 text-xs">
                                                <span style={{ color: "var(--theme-secondary)" }}>
                                                    <FormattedDate date={blog.data.pubDate} />
                                                </span>
                                                <span style={{ color: "var(--theme-muted)" }}>
                                                    {blog.data.read_time || 4} min read
                                                </span>
                                                <span style={{ color: "var(--theme-accent)" }}>
                                                    Open →
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                        ))
                    }
                    </div>
                </section>
            </div>
        </div>
        <Footer />
    </body>
</html>
