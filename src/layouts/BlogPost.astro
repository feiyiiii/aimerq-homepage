---
// import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
// import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import BlogHeader from "../components/BlogHeader.astro";
import BlogContent from "../components/BlogContent.astro";

type Props = CollectionEntry<"blog">;

const { ...post } = Astro.props;
---

<html lang="zh-CN" data-theme="light">
	<head>
		<BaseHead title={post.data.title} description={post.data.description} />
		<style>
			.blog-page {
				position: relative;
				min-height: 100vh;
				padding-bottom: 3rem;
				transition: background 300ms ease, color 300ms ease;
				color: var(--blog-text);
			}

			.blog-page::before,
			.blog-page::after {
				content: "";
				position: absolute;
				pointer-events: none;
				border-radius: 999px;
				filter: blur(70px);
				opacity: 0.5;
			}

			.blog-page::before {
				top: 4rem;
				left: -5rem;
				width: 240px;
				height: 240px;
				background: var(--blog-blur-one);
			}

			.blog-page::after {
				right: -5rem;
				top: 16rem;
				width: 300px;
				height: 300px;
				background: var(--blog-blur-two);
			}

			.blog-shell {
				position: relative;
				z-index: 1;
				max-width: 920px;
				margin: 0 auto;
				padding: 2rem 1rem 0;
			}

			.blog-header-card {
				border: 1px solid var(--blog-border);
				background: var(--blog-panel-bg);
				border-radius: 28px;
				box-shadow: var(--blog-panel-shadow);
				backdrop-filter: blur(8px);
				overflow: hidden;
			}

			.blog-header-body {
				padding: 1.35rem 1.15rem 1.45rem;
			}

			.blog-toolbar {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				justify-content: flex-start;
				margin-bottom: 0.9rem;
			}

			.blog-toolbar-group {
				display: flex;
				flex-wrap: wrap;
				gap: 0.65rem;
			}

			.blog-toolbar-link {
				display: inline-flex;
				align-items: center;
				padding: 0.42rem 0.82rem;
				border-radius: 999px;
				border: 1px solid var(--blog-border);
				color: var(--blog-muted);
				font-size: 0.8rem;
				font-weight: 600;
				letter-spacing: 0;
				text-decoration: none;
				background: rgba(255, 255, 255, 0.45);
				transition: transform 180ms ease, background 180ms ease, border-color 180ms ease;
			}

			.blog-toolbar-link:hover {
				transform: translateY(-1px);
				background: var(--blog-chip-bg);
			}

			.blog-toolbar-link-primary {
				color: var(--blog-accent);
				border-color: color-mix(in srgb, var(--blog-accent) 50%, transparent);
				background: color-mix(in srgb, var(--blog-accent) 16%, transparent);
			}

			.blog-toolbar-link-ghost {
				background: rgba(255, 255, 255, 0.75);
			}

			.blog-title {
				font-size: clamp(2rem, 4.2vw, 2.7rem);
				line-height: 1.25;
				font-weight: 680;
				color: var(--blog-text);
				margin: 0 0 0.95rem;
				letter-spacing: -0.01em;
			}

			.blog-hero-wrap {
				margin: 0 0 1.25rem;
			}

			.blog-hero-image {
				width: 100%;
				display: block;
				border-radius: 18px;
				border: 1px solid var(--blog-border);
				box-shadow: var(--blog-media-shadow);
				object-fit: cover;
			}

			.blog-meta-row {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.42rem 0.72rem;
				border-radius: 999px;
				background: var(--blog-chip-bg);
				border: 1px solid var(--blog-border);
				color: var(--blog-muted);
				font-size: 0.84rem;
				margin-bottom: 0.9rem;
			}

			.blog-meta-dot {
				opacity: 0.5;
			}

			.blog-action-row {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.6rem;
			}

			.blog-article-card {
				margin-top: 1.2rem;
				border: 1px solid var(--blog-border);
				background: var(--blog-article-bg);
				border-radius: 26px;
				box-shadow: var(--blog-panel-shadow);
				overflow: hidden;
			}

			.blog-article-body {
				padding: 1.6rem 1.25rem;
			}

			.blog-page :global(.prose) {
				max-width: none;
				color: var(--blog-text);
			}

			.blog-page :global(.prose p) {
				line-height: 1.9;
				font-size: 1.04rem;
				color: var(--blog-text);
			}

			.blog-page :global(.prose h1),
			.blog-page :global(.prose h2),
			.blog-page :global(.prose h3),
			.blog-page :global(.prose h4),
			.blog-page :global(.prose h5),
			.blog-page :global(.prose h6) {
				color: var(--blog-heading);
			}

			.blog-page :global(.prose ul) {
				list-style: disc;
				padding-left: 1.2rem;
				color: var(--blog-text);
			}

			.blog-page :global(.prose li) {
				margin-bottom: 0.35rem;
			}

			.blog-page :global(.prose img) {
				border-radius: 14px;
				border: 1px solid var(--blog-border);
				box-shadow: var(--blog-media-shadow);
			}

			body[data-blog-style="aurora"] {
				--blog-bg: radial-gradient(circle at 12% 15%, #dff7ff 0, transparent 42%),
					radial-gradient(circle at 90% 18%, #f2ebff 0, transparent 34%),
					radial-gradient(circle at 42% 98%, #dbf9ee 0, transparent 42%),
					#f6f8ff;
				--blog-text: #142039;
				--blog-heading: #101a35;
				--blog-muted: #4a6088;
				--blog-panel-bg: rgba(255, 255, 255, 0.78);
				--blog-article-bg: rgba(255, 255, 255, 0.92);
				--blog-border: rgba(92, 115, 169, 0.25);
				--blog-chip-bg: rgba(215, 230, 255, 0.4);
				--blog-accent: #2556d8;
				--blog-accent-contrast: #ffffff;
				--blog-panel-shadow: 0 18px 45px rgba(57, 90, 176, 0.16);
				--blog-media-shadow: 0 16px 34px rgba(70, 98, 166, 0.22);
				--blog-blur-one: rgba(146, 204, 255, 0.9);
				--blog-blur-two: rgba(195, 183, 255, 0.85);
			}

			.blog-page {
				background: var(--blog-bg);
			}

			body[data-blog-style="aurora"] .blog-page {
				font-family: "IBM Plex Sans", "Segoe UI", "Helvetica Neue", sans-serif;
			}

			@media (min-width: 768px) {
				.blog-shell {
					padding-top: 2.5rem;
				}

				.blog-header-body {
					padding: 2.2rem;
				}

				.blog-article-body {
					padding: 2.1rem;
				}
			}
		</style>
	</head>

	<body data-blog-style="aurora">
		<Header />
		<div class="blog-page">
			<div class="blog-shell">
				<BlogHeader {...Astro.props} />
				<div class="blog-article-card">
					<div class="blog-article-body">
						<BlogContent {...Astro.props} />
					</div>
				</div>
			</div>
		</div>
		<Footer />
	</body>
</html>
