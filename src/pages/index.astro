---
import BaseHead from "../components/BaseHead.astro";
import CommandOutput from "../components/CommandOutput.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE, terminalConfig } from "../consts";
import profileConfig from "../../profile.config";
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div
			class="min-h-screen flex flex-col"
			style={{
				backgroundColor: "var(--theme-background)",
				color: "var(--theme-text)",
			}}
		>
			<Header />
			<main>
				<div
					class="pt-0 font-mono space-y-6 overflow-y-auto h-[calc(100vh-160px)] max-w-screen-xl mx-auto px-3 py-4 sm:px-6 sm:py-8"
					style={{
						backgroundColor: "var(--theme-background)",
						color: "var(--theme-text)",
						fontFamily: "var(--theme-fontFamily)",
					}}
				>
					<section
						class="rounded-3xl p-6 sm:p-10 futuristic-panel"
						style={{
							border: `1px solid var(--theme-welcomeBoxBorder)`,
							backgroundColor: "var(--theme-welcomeBoxBg)",
						}}
					>
						<div class="grid gap-8 lg:grid-cols-[1.5fr_0.9fr] lg:items-end">
							<div>
								<div class="flex flex-wrap gap-2 mb-5">
									<span class="f-chip">Human Resources</span>
									<span class="f-chip">Business Partnering</span>
									<span class="f-chip">Organization Growth</span>
								</div>
								<div
									class="text-xs sm:text-sm mb-3 tracking-[0.25em] uppercase"
									style={{ color: "var(--theme-secondary)" }}
								>
									AimerQ / Personal Interface
								</div>
								<h1
									class="text-3xl sm:text-5xl leading-tight font-semibold tracking-tight mb-5"
									style={{ color: "var(--theme-text)" }}
								>
									懂技术，也懂业务。
									<br />
									把组织问题看清，也把人的感受放进去。
								</h1>
								<p
									class="text-base sm:text-lg leading-8 max-w-3xl mb-4"
									style={{ color: "var(--theme-outputText)" }}
								>
									我是 {profileConfig.profile.name}。我更喜欢把 HR 理解成一种精密而温和的系统设计:
									它既要理解业务，也要理解组织，更要理解人如何在高压和变化中继续稳定地工作、成长与协同。
								</p>
								<p
									class="text-sm sm:text-base leading-8 max-w-3xl"
									style={{ color: "var(--theme-muted)" }}
								>
									这不是一页“模板化简历”，而是一张更接近我真实表达方式的界面。它关于业务、人才、组织，也关于那些我希望在工作里始终保留下来的清醒、分寸和温度。
								</p>
							</div>

							<div class="futuristic-panel rounded-3xl p-5 sm:p-6">
								<div
									class="text-xs uppercase tracking-[0.25em] mb-4"
									style={{ color: "var(--theme-secondary)" }}
								>
									Current Focus
								</div>
								<div class="space-y-3">
									<div class="f-metric">
										<span class="f-metric-label">Role</span>
										<span class="f-metric-value">HRBP / OD</span>
									</div>
									<div class="f-metric">
										<span class="f-metric-label">Location</span>
										<span class="f-metric-value">Beijing</span>
									</div>
									<div class="f-metric">
										<span class="f-metric-label">Keywords</span>
										<span class="f-metric-value">People, Business, Time</span>
									</div>
									<div class="f-metric">
										<span class="f-metric-label">Contact</span>
										<span class="f-metric-value">qinfeiyii@gmail.com</span>
									</div>
								</div>
							</div>
						</div>
					</section>

					<section class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-5">
						<div
							class="rounded-3xl p-6 sm:p-8 futuristic-panel"
							style={{
								backgroundColor: "var(--theme-welcomeBoxBg)",
								border: `1px solid var(--theme-border)`,
							}}
						>
							<div
								class="text-xs sm:text-sm mb-4 tracking-[0.25em] uppercase"
								style={{ color: "var(--theme-secondary)" }}
							>
								About
							</div>
							<h2
								class="text-2xl sm:text-3xl leading-tight font-semibold mb-4"
								style={{ color: "var(--theme-text)" }}
							>
								我想做的，不只是把流程跑通。
							</h2>
							<div class="space-y-4 text-sm sm:text-base leading-8" style={{ color: "var(--theme-outputText)" }}>
								<p>
									我关心招聘是不是贴近真实业务，关心组织有没有为人留下成长空间，也关心一项制度落地时，最终会怎样落在人身上。
								</p>
								<p>
									我喜欢把复杂问题拆开来看，也喜欢在看似理性的系统里，为人保留一点缓冲、理解与余地。对我来说，专业不是冷，而是稳。
								</p>
							</div>
						</div>

						<div class="grid gap-5">
							<div
								class="rounded-3xl p-5 futuristic-panel"
								style={{
									backgroundColor: "var(--theme-welcomeBoxBg)",
									border: `1px solid var(--theme-border)`,
								}}
							>
								<div class="f-section-title">What I Do</div>
								<ul class="f-list">
									<li>业务伙伴支持，让人力工作真正进入业务现场</li>
									<li>招聘与人才配置，让关键岗位和合适的人更准确地相遇</li>
									<li>组织发展与人才培养，让能力在团队里长期沉淀</li>
								</ul>
							</div>

							<div
								class="rounded-3xl p-5 futuristic-panel"
								style={{
									backgroundColor: "var(--theme-welcomeBoxBg)",
									border: `1px solid var(--theme-border)`,
								}}
							>
								<div class="f-section-title">What I Believe</div>
								<ul class="f-list">
									<li>业务理解和人文关怀，不必二选一</li>
									<li>效率不该以忽视人的感受为代价</li>
									<li>真正稳健的团队，来自长期积累</li>
								</ul>
							</div>
						</div>
					</section>

					<section class="grid grid-cols-1 sm:grid-cols-3 gap-5">
								<div
									class="rounded-3xl p-5 futuristic-panel"
									style={{
										backgroundColor:
											"var(--theme-welcomeBoxBg)",
										border: `1px solid var(--theme-border)`,
									}}
								>
									<div class="f-section-title">Business</div>
									<p class="text-sm leading-7" style={{ color: "var(--theme-outputText)" }}>
										理解业务节奏、团队诉求和关键岗位的重要性，让 HR 真正贴近现实，也贴近结果。
									</p>
								</div>

								<div
									class="rounded-3xl p-5 futuristic-panel"
									style={{
										backgroundColor:
											"var(--theme-welcomeBoxBg)",
										border: `1px solid var(--theme-border)`,
									}}
								>
									<div class="f-section-title">People</div>
									<p class="text-sm leading-7" style={{ color: "var(--theme-outputText)" }}>
										关注人的匹配、成长、尊严和潜能释放，不想把人变成流程里的一个零件。
									</p>
								</div>

								<div
									class="rounded-3xl p-5 futuristic-panel"
									style={{
										backgroundColor: "var(--theme-welcomeBoxBg)",
										border: `1px solid var(--theme-border)`,
									}}
								>
									<div class="f-section-title">Time</div>
									<p class="text-sm leading-7" style={{ color: "var(--theme-outputText)" }}>
										相信长期主义。很多重要的事不会立刻发光，但只要方向对，就值得慢慢做下去。
									</p>
								</div>
					</section>

					<section class="grid grid-cols-1 sm:grid-cols-2 gap-5">
								<a
									href="/blogs"
									class="rounded-3xl p-6 block transition-all duration-300 hover:-translate-y-1 futuristic-panel"
									style={{
										backgroundColor: "var(--theme-welcomeBoxBg)",
										border: `1px solid var(--theme-border)`,
									}}
								>
									<div
										class="text-xs uppercase tracking-[0.25em] mb-3"
										style={{ color: "var(--theme-secondary)" }}
									>
										Reflections
									</div>
									<h3
										class="text-2xl font-semibold mb-3"
										style={{ color: "var(--theme-text)" }}
									>
										生活感悟
									</h3>
									<p
										class="text-sm leading-7"
										style={{ color: "var(--theme-outputText)" }}
									>
										记录我对工作、关系、成长和日常心绪的感受。不是大道理，只是一些慢慢想明白的话。
									</p>
									<div class="mt-4 text-xs" style={{ color: "var(--theme-secondary)" }}>
										View writings →
									</div>
								</a>
								<a
									href="/blogs"
									class="rounded-3xl p-6 block transition-all duration-300 hover:-translate-y-1 futuristic-panel"
									style={{
										backgroundColor: "var(--theme-welcomeBoxBg)",
										border: `1px solid var(--theme-border)`,
									}}
								>
									<div
										class="text-xs uppercase tracking-[0.25em] mb-3"
										style={{ color: "var(--theme-accent)" }}
									>
										Reading Notes
									</div>
									<h3
										class="text-2xl font-semibold mb-3"
										style={{ color: "var(--theme-text)" }}
									>
										读书笔记
									</h3>
									<p
										class="text-sm leading-7"
										style={{ color: "var(--theme-outputText)" }}
									>
										摘录那些让我停下来的一段话，整理读完一本书之后真正留在心里的部分，看它们怎样回到生活里。
									</p>
									<div class="mt-4 text-xs" style={{ color: "var(--theme-accent)" }}>
										Explore notes →
									</div>
								</a>
					</section>

					<section
						class="rounded-3xl p-6 sm:p-8 futuristic-panel"
						style={{
							backgroundColor: "var(--theme-welcomeBoxBg)",
							border: `1px solid var(--theme-border)`,
						}}
					>
								<div
									class="text-xs sm:text-sm mb-3 tracking-[0.25em] uppercase"
									style={{ color: "var(--theme-secondary)" }}
								>
									Contact
								</div>
								<p
									class="text-lg sm:text-2xl leading-9 mb-3 max-w-3xl"
									style={{ color: "var(--theme-text)" }}
								>
									如果你也在关心团队、人才、组织，欢迎来找我。
								</p>
								<p
									class="text-sm sm:text-base leading-8 mb-4 max-w-3xl"
									style={{ color: "var(--theme-outputText)" }}
								>
									也许我们会聊到业务、聊到成长，或者聊到那些看起来很小、其实很重要的事。
								</p>
								<div class="flex flex-wrap gap-3 text-sm">
									<span class="f-chip">qinfeiyii@gmail.com</span>
									<span class="f-chip">Beijing</span>
									<span class="f-chip">GitHub /feiyiiii</span>
								</div>
					</section>

					<div id="command-output" class="hidden">
						<CommandOutput
							output={[
								{
									type: "command",
									text: ["about", "skills", "notes", "contact"],
								},
							]}
						/>
					</div>
				</div>
			</main>
			<Footer />
		</div>
	</body>
</html>
