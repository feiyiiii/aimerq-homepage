---
import { GitHubRepo } from "../types";
import { getLanguageColor } from "../utils/theme";

const { allRepo } = Astro.props;
---

<div class="mb-8">
    <h2 class="text-lg font-semibold mb-4" style={{ color: "var(--theme-primary)" }}>
        <span style={{ color: "var(--theme-muted)" }}>## </span>"All Projects and Repositories"
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
            allRepo.map((repo: GitHubRepo, index: number) => (
                <div
                    id={`project-${index}`}
                    class="rounded-lg p-4 transition-colors hover:opacity-90"
                    style={{
                        backgroundColor: "var(--theme-welcomeBoxBg)",
                        border: "1px solid var(--theme-border)",
                    }}
                >
                    <div class="flex justify-between items-start mb-3">
                        <h3 class="font-semibold text-lg">
                            <a
                                href={repo.html_url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="hover:underline"
                                style={{ color: "var(--theme-secondary)" }}
                            >
                                {repo.name}
                            </a>
                        </h3>
                        <div class="flex items-center space-x-2 text-sm">
                            {repo.stargazers_count > 0 && (
                                <span style={{ color: "var(--theme-warning)" }}>
                                    ⭐ {repo.stargazers_count}
                                </span>
                            )}
                            {repo.forks_count > 0 && (
                                <span style={{ color: "var(--theme-accent)" }}>
                                    🍴 {repo.forks_count}
                                </span>
                            )}
                        </div>
                    </div>
                    <p class="text-sm mb-5 line-clamp-5" style={{ color: "var(--theme-outputText)" }}>
                        {repo.description || "No description available"}
                    </p>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-2">
                            {repo.primaryLanguages &&
                            repo.primaryLanguages.length > 0 ? (
                                <div class="flex items-center space-x-2">
                                    {repo.primaryLanguages.map(
                                        (lang, langIndex) => (
                                            <div
                                                id={`lang-${langIndex}`}
                                                class="flex items-center space-x-1"
                                            >
                                                <div
                                                    class="w-3 h-3 rounded-full"
                                                    style={{
                                                        backgroundColor:
                                                            getLanguageColor(
                                                                lang,
                                                            ),
                                                    }}
                                                />
                                                <span class="text-sm" style={{ color: "var(--theme-muted)" }}>
                                                    {lang}
                                                </span>
                                            </div>
                                        ),
                                    )}
                                </div>
                            ) : (
                                repo.primaryLanguages && (
                                    <div class="flex items-center space-x-1">
                                        <div
                                            class="w-3 h-3 rounded-full"
                                            style={{
                                                backgroundColor:
                                                    getLanguageColor(
                                                        repo
                                                            .primaryLanguages[0],
                                                    ),
                                            }}
                                        />
                                        <span class="text-sm" style={{ color: "var(--theme-muted)" }}>
                                            {repo.primaryLanguages[0]}
                                        </span>
                                    </div>
                                )
                            )}
                        </div>
                        <span class="text-xs" style={{ color: "var(--theme-muted)" }}>
                            {repo.updated_at}
                        </span>
                    </div>
                </div>
            ))
        }
    </div>
</div>
