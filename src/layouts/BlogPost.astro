---
// import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
// import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import BlogHeader from "../components/BlogHeader.astro";
import BlogContent from "../components/BlogContent.astro";

type Props = CollectionEntry<"blog">;

const { ...post } = Astro.props;
---

<html lang="zh-CN" data-theme="light">
	<head>
		<BaseHead title={post.data.title} description={post.data.description} />
		<style>
			.blog-page {
				position: relative;
				min-height: 100vh;
				padding-bottom: 3rem;
				transition: background 300ms ease, color 300ms ease;
				color: var(--blog-text);
			}

			.blog-page::before,
			.blog-page::after {
				content: "";
				position: absolute;
				pointer-events: none;
				border-radius: 999px;
				filter: blur(70px);
				opacity: 0.5;
			}

			.blog-page::before {
				top: 4rem;
				left: -5rem;
				width: 240px;
				height: 240px;
				background: var(--blog-blur-one);
			}

			.blog-page::after {
				right: -5rem;
				top: 16rem;
				width: 300px;
				height: 300px;
				background: var(--blog-blur-two);
			}

			.blog-shell {
				position: relative;
				z-index: 1;
				max-width: 920px;
				margin: 0 auto;
				padding: 2rem 1rem 0;
			}

			.blog-header-card {
				border: 1px solid var(--blog-border);
				background: var(--blog-panel-bg);
				border-radius: 28px;
				box-shadow: var(--blog-panel-shadow);
				backdrop-filter: blur(8px);
				overflow: hidden;
			}

			.blog-header-body {
				padding: 1.75rem 1.25rem;
			}

			.blog-toolbar {
				display: flex;
				flex-wrap: wrap;
				gap: 0.65rem;
				justify-content: space-between;
				margin-bottom: 1.25rem;
			}

			.blog-toolbar-link {
				display: inline-flex;
				align-items: center;
				padding: 0.4rem 0.8rem;
				border-radius: 999px;
				border: 1px solid var(--blog-border);
				color: var(--blog-muted);
				font-size: 0.85rem;
				font-weight: 600;
				letter-spacing: 0.01em;
				text-decoration: none;
				transition: transform 200ms ease, background 200ms ease, border-color 200ms ease;
			}

			.blog-toolbar-link:hover {
				transform: translateY(-1px);
				background: var(--blog-chip-bg);
			}

			.blog-toolbar-link-primary {
				color: var(--blog-accent);
				border-color: color-mix(in srgb, var(--blog-accent) 50%, transparent);
				background: color-mix(in srgb, var(--blog-accent) 16%, transparent);
			}

			.blog-title {
				font-size: clamp(2rem, 5vw, 3.25rem);
				line-height: 1.18;
				font-weight: 700;
				color: var(--blog-text);
				margin: 0 0 1.25rem;
				letter-spacing: -0.01em;
			}

			.blog-hero-wrap {
				margin: 0 0 1.25rem;
			}

			.blog-hero-image {
				width: 100%;
				display: block;
				border-radius: 18px;
				border: 1px solid var(--blog-border);
				box-shadow: var(--blog-media-shadow);
				object-fit: cover;
			}

			.blog-meta-row {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.45rem 0.75rem;
				border-radius: 999px;
				background: var(--blog-chip-bg);
				border: 1px solid var(--blog-border);
				color: var(--blog-muted);
				font-size: 0.86rem;
				margin-bottom: 1rem;
			}

			.blog-meta-dot {
				opacity: 0.5;
			}

			.blog-style-switcher {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.5rem;
				margin-top: 0.25rem;
			}

			.blog-style-label {
				font-size: 0.8rem;
				color: var(--blog-muted);
				margin-right: 0.35rem;
			}

			.blog-style-btn {
				border: 1px solid var(--blog-border);
				background: var(--blog-chip-bg);
				color: var(--blog-text);
				padding: 0.35rem 0.7rem;
				border-radius: 999px;
				font-size: 0.78rem;
				cursor: pointer;
				transition: all 180ms ease;
			}

			.blog-style-btn:hover {
				transform: translateY(-1px);
				border-color: var(--blog-accent);
			}

			.blog-style-btn.is-active {
				color: var(--blog-accent-contrast);
				background: var(--blog-accent);
				border-color: var(--blog-accent);
			}

			.blog-article-card {
				margin-top: 1.2rem;
				border: 1px solid var(--blog-border);
				background: var(--blog-article-bg);
				border-radius: 26px;
				box-shadow: var(--blog-panel-shadow);
				overflow: hidden;
			}

			.blog-article-body {
				padding: 1.6rem 1.25rem;
			}

			.blog-page :global(.prose) {
				max-width: none;
				color: var(--blog-text);
			}

			.blog-page :global(.prose p) {
				line-height: 1.9;
				font-size: 1.04rem;
				color: var(--blog-text);
			}

			.blog-page :global(.prose h1),
			.blog-page :global(.prose h2),
			.blog-page :global(.prose h3),
			.blog-page :global(.prose h4),
			.blog-page :global(.prose h5),
			.blog-page :global(.prose h6) {
				color: var(--blog-heading);
			}

			.blog-page :global(.prose ul) {
				list-style: disc;
				padding-left: 1.2rem;
				color: var(--blog-text);
			}

			.blog-page :global(.prose li) {
				margin-bottom: 0.35rem;
			}

			.blog-page :global(.prose img) {
				border-radius: 14px;
				border: 1px solid var(--blog-border);
				box-shadow: var(--blog-media-shadow);
			}

			body[data-blog-style="aurora"] {
				--blog-bg: radial-gradient(circle at 12% 15%, #dff7ff 0, transparent 42%),
					radial-gradient(circle at 90% 18%, #f2ebff 0, transparent 34%),
					radial-gradient(circle at 42% 98%, #dbf9ee 0, transparent 42%),
					#f6f8ff;
				--blog-text: #142039;
				--blog-heading: #101a35;
				--blog-muted: #4a6088;
				--blog-panel-bg: rgba(255, 255, 255, 0.78);
				--blog-article-bg: rgba(255, 255, 255, 0.92);
				--blog-border: rgba(92, 115, 169, 0.25);
				--blog-chip-bg: rgba(215, 230, 255, 0.4);
				--blog-accent: #2556d8;
				--blog-accent-contrast: #ffffff;
				--blog-panel-shadow: 0 18px 45px rgba(57, 90, 176, 0.16);
				--blog-media-shadow: 0 16px 34px rgba(70, 98, 166, 0.22);
				--blog-blur-one: rgba(146, 204, 255, 0.9);
				--blog-blur-two: rgba(195, 183, 255, 0.85);
			}

			body[data-blog-style="paper"] {
				--blog-bg: radial-gradient(circle at 88% 8%, rgba(255, 229, 168, 0.32), transparent 34%),
					linear-gradient(165deg, #f7f2e8 0%, #efe8dc 100%);
				--blog-text: #2d241e;
				--blog-heading: #221c19;
				--blog-muted: #776255;
				--blog-panel-bg: rgba(255, 251, 244, 0.94);
				--blog-article-bg: rgba(255, 253, 248, 0.98);
				--blog-border: rgba(132, 104, 82, 0.24);
				--blog-chip-bg: rgba(255, 245, 227, 0.8);
				--blog-accent: #935b2c;
				--blog-accent-contrast: #fffaf1;
				--blog-panel-shadow: 0 14px 32px rgba(113, 84, 58, 0.12);
				--blog-media-shadow: 0 14px 28px rgba(113, 84, 58, 0.16);
				--blog-blur-one: rgba(255, 227, 165, 0.55);
				--blog-blur-two: rgba(255, 205, 160, 0.45);
			}

			body[data-blog-style="ink"] {
				--blog-bg: radial-gradient(circle at 10% 10%, rgba(50, 86, 147, 0.35), transparent 44%),
					radial-gradient(circle at 88% 16%, rgba(14, 150, 123, 0.2), transparent 36%),
					linear-gradient(145deg, #081425 0%, #0f2336 100%);
				--blog-text: #deedff;
				--blog-heading: #f3f9ff;
				--blog-muted: #9fb8dd;
				--blog-panel-bg: rgba(11, 26, 42, 0.72);
				--blog-article-bg: rgba(11, 28, 45, 0.82);
				--blog-border: rgba(110, 149, 214, 0.28);
				--blog-chip-bg: rgba(38, 63, 95, 0.58);
				--blog-accent: #67d2ff;
				--blog-accent-contrast: #0d2232;
				--blog-panel-shadow: 0 20px 45px rgba(2, 11, 25, 0.52);
				--blog-media-shadow: 0 22px 44px rgba(4, 14, 34, 0.55);
				--blog-blur-one: rgba(24, 106, 177, 0.65);
				--blog-blur-two: rgba(18, 156, 132, 0.52);
			}

			.blog-page {
				background: var(--blog-bg);
			}

			body[data-blog-style="paper"] .blog-page {
				font-family: "Noto Serif SC", "Songti SC", "STSong", serif;
			}

			body[data-blog-style="aurora"] .blog-page,
			body[data-blog-style="ink"] .blog-page {
				font-family: "IBM Plex Sans", "Segoe UI", "Helvetica Neue", sans-serif;
			}

			@media (min-width: 768px) {
				.blog-shell {
					padding-top: 2.5rem;
				}

				.blog-header-body {
					padding: 2.2rem;
				}

				.blog-article-body {
					padding: 2.1rem;
				}
			}
		</style>
	</head>

	<body data-blog-style="aurora">
		<Header />
		<div class="blog-page">
			<div class="blog-shell">
				<BlogHeader {...Astro.props} />
				<div class="blog-article-card">
					<div class="blog-article-body">
						<BlogContent {...Astro.props} />
					</div>
				</div>
			</div>
		</div>
		<script is:inline>
			(() => {
				const key = "aimerq-blog-style";
				const allowed = ["aurora", "paper", "ink"];
				const body = document.body;
				const buttons = Array.from(document.querySelectorAll(".blog-style-btn"));
				const applyStyle = (style) => {
					const selected = allowed.includes(style) ? style : "aurora";
					body.setAttribute("data-blog-style", selected);
					buttons.forEach((button) => {
						const active = button.dataset.blogStyle === selected;
						button.classList.toggle("is-active", active);
						button.setAttribute("aria-pressed", String(active));
					});
				};

				const saved = localStorage.getItem(key);
				applyStyle(saved || "aurora");

				buttons.forEach((button) => {
					button.addEventListener("click", () => {
						const style = button.dataset.blogStyle || "aurora";
						applyStyle(style);
						localStorage.setItem(key, style);
					});
				});
			})();
		</script>
		<Footer />
	</body>
</html>
