---
import { Image } from "astro:assets";
import FormattedDate from "./FormattedDate.astro";

const { ...post } = Astro.props;
const entry = post as {
    id: string;
    filePath?: string;
    data: {
        title: string;
        heroImage?: any;
        pubDate: Date;
        read_time?: number;
    };
};

const sourcePath = entry.filePath || `src/content/blog/${entry.id}.md`;
const editPostUrl = `https://github.com/feiyiiii/aimerq-homepage/edit/main/${sourcePath}`;
---

<header class="blog-header-card">
    <div class="blog-header-body">
        <nav class="blog-toolbar">
            <a class="blog-toolbar-link" href="/blogs">← 返回归档</a>
            <a
                class="blog-toolbar-link blog-toolbar-link-primary"
                href={editPostUrl}
                target="_blank"
                rel="noreferrer"
            >
                编辑此文
            </a>
        </nav>

        <h1 class="blog-title">{entry.data.title}</h1>

        {
            entry.data.heroImage && (
                <div class="blog-hero-wrap">
                    <Image
                        class="blog-hero-image"
                        src={entry.data.heroImage}
                        alt={entry.data.title}
                    />
                </div>
            )
        }

        <div class="blog-meta-row">
            <span class="blog-meta-item">
                <FormattedDate date={entry.data.pubDate} />
            </span>
            <span class="blog-meta-dot">•</span>
            <span class="blog-meta-item">{entry.data.read_time || 4} min read</span>
        </div>

        <div class="blog-style-switcher" aria-label="博客风格切换">
            <span class="blog-style-label">页面风格</span>
            <button class="blog-style-btn" type="button" data-blog-style="aurora">
                版本 A
            </button>
            <button class="blog-style-btn" type="button" data-blog-style="paper">
                版本 B
            </button>
            <button class="blog-style-btn" type="button" data-blog-style="ink">
                版本 C
            </button>
        </div>
    </div>
</header>
