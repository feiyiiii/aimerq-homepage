---
import { getLanguageColor } from "../utils/theme";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import githubData from "../data/github-projects.json" assert { type: "json" };
import FeatureRepo from "../components/FeatureRepo.astro";
import ProjectsUpdateDate from "../components/ProjectsUpdateDate.astro";
import AllRepo from "../components/AllRepo.astro";
---

<!doctype html>
<html lang="en" data-theme="dark">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body>
        <div
            class="min-h-screen flex flex-col"
            style={{
                backgroundColor: "var(--theme-background)",
                color: "var(--theme-text)",
            }}
        >
            <Header />
            <div
                class="min-h-screen font-mono pb-16"
                style={{
                    backgroundColor: "var(--theme-background)",
                    color: "var(--theme-text)",
                }}
            >
                <div class="max-w-6xl mx-auto py-4 sm:py-8 px-2 sm:px-4">
                    {/* Terminal navigation */}
                    <div class="mb-4 sm:mb-6">
                        <div
                            class="rounded-lg p-3 sm:p-4"
                            style={{
                                backgroundColor: "var(--theme-welcomeBoxBg)",
                                border: "1px solid var(--theme-border)",
                            }}
                        >
                            <div
                                class="flex flex-col sm:flex-row sm:items-center space-y-2 sm:space-y-0 sm:space-x-2"
                            >
                                <div
                                    class="flex items-center space-x-1 text-xs sm:text-sm"
                                >
                                    <span class="hidden sm:inline" style={{ color: "var(--theme-secondary)" }}
                                        >user@localhost</span
                                    >
                                    <span class="hidden sm:inline" style={{ color: "var(--theme-text)" }}
                                        >:</span
                                    >
                                    <span class="hidden sm:inline" style={{ color: "var(--theme-promptPath)" }}
                                        >~/projects</span
                                    >
                                    <span style={{ color: "var(--theme-text)" }}>$ </span>
                                    <a
                                        href="/"
                                        class="hover:opacity-75 underline transition-opacity"
                                        style={{ color: "var(--theme-primary)" }}
                                    >
                                        cd ~
                                    </a>
                                </div>
                                <span class="text-xs sm:text-sm" style={{ color: "var(--theme-muted)" }}
                                    ># Back to home</span
                                >
                            </div>
                        </div>
                    </div>

                    {/* Terminal window */}
                    <div
                        class="rounded-t-lg"
                        style={{
                            backgroundColor: "var(--theme-welcomeBoxBg)",
                            border: "1px solid var(--theme-border)",
                        }}
                    >
                        <div
                            class="flex flex-col sm:flex-row sm:items-center sm:justify-between p-3 sm:p-4 space-y-2 sm:space-y-0"
                            style={{ borderBottom: "1px solid var(--theme-border)" }}
                        >
                            <div class="flex items-center space-x-2">
                                <div class="w-3 h-3 rounded-full" style={{ backgroundColor: "var(--theme-error)" }}>
                                </div>
                                <div class="w-3 h-3 rounded-full" style={{ backgroundColor: "var(--theme-warning)" }}>
                                </div>
                                <div class="w-3 h-3 rounded-full" style={{ backgroundColor: "var(--theme-success)" }}>
                                </div>
                                <span
                                    class="text-xs sm:text-sm ml-4"
                                    style={{ color: "var(--theme-muted)" }}
                                    >~/projects/github-repos</span
                                >
                            </div>
                            <div class="text-xs" style={{ color: "var(--theme-muted)" }}>
                                gh repo list --limit 100
                            </div>
                        </div>
                    </div>

                    <div
                        class="rounded-b-lg p-4 sm:p-8"
                        style={{
                            backgroundColor: "var(--theme-background)",
                            border: "1px solid var(--theme-border)",
                            borderTop: "none",
                        }}
                    >
                        {/* Header */}
                        <div class="mb-6 pb-4" style={{ borderBottom: "1px solid var(--theme-border)" }}>
                            <div class="text-sm mb-2" style={{ color: "var(--theme-muted)" }}>
                                <span style={{ color: "var(--theme-secondary)" }}>$ </span>
                                <span
                                    >gh repo list @{githubData.user.login} --json
                                    name,description,language,stars</span
                                >
                            </div>
                            <div class="text-sm mb-2" style={{ color: "var(--theme-muted)" }}>
                                <span style={{ color: "var(--theme-secondary)" }}>$ </span>
                                <span
                                    >gh api user/repos | jq '.[] | .language' |
                                    sort | uniq</span
                                >
                                <span class="ml-2" style={{ color: "var(--theme-muted)" }}
                                    ># Show all languages</span
                                >
                            </div>
                            <h1
                                class="text-2xl sm:text-3xl font-bold mb-4"
                                style={{ color: "var(--theme-primary)" }}
                            >
                                <span style={{ color: "var(--theme-muted)" }}># </span>GitHub
                                Projects
                            </h1>
                            <div
                                class="flex flex-wrap items-center gap-4 text-sm"
                            >
                                <span style={{ color: "var(--theme-secondary)" }}
                                    >👤 @{githubData.user.login}</span
                                >
                                <span style={{ color: "var(--theme-warning)" }}
                                    >📁 {githubData.stats.totalRepos} repos</span
                                >
                                <span style={{ color: "var(--theme-accent)" }}
                                    >⭐ {githubData.stats.totalStars} stars</span
                                >
                                <span style={{ color: "var(--theme-primary)" }}
                                    >🍴 {githubData.stats.totalForks} forks</span
                                >
                            </div>
                        </div>

                        {/* GitHub Stats */}
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
                            <div
                                class="rounded-lg p-4 text-center"
                                style={{
                                    backgroundColor: "var(--theme-welcomeBoxBg)",
                                    border: "1px solid var(--theme-border)",
                                }}
                            >
                                <div class="text-2xl font-bold" style={{ color: "var(--theme-secondary)" }}>
                                    {githubData.stats.totalRepos}
                                </div>
                                <div class="text-sm" style={{ color: "var(--theme-muted)" }}>Repos</div>
                            </div>
                            <div
                                class="rounded-lg p-4 text-center"
                                style={{
                                    backgroundColor: "var(--theme-welcomeBoxBg)",
                                    border: "1px solid var(--theme-border)",
                                }}
                            >
                                <div class="text-2xl font-bold" style={{ color: "var(--theme-warning)" }}>
                                    {githubData.stats.totalStars}
                                </div>
                                <div class="text-sm" style={{ color: "var(--theme-muted)" }}>
                                    Total Stars
                                </div>
                            </div>
                            <div
                                class="rounded-lg p-4 text-center"
                                style={{
                                    backgroundColor: "var(--theme-welcomeBoxBg)",
                                    border: "1px solid var(--theme-border)",
                                }}
                            >
                                <div class="text-2xl font-bold" style={{ color: "var(--theme-accent)" }}>
                                    {githubData.stats.totalForks}
                                </div>
                                <div class="text-sm" style={{ color: "var(--theme-muted)" }}>
                                    Total Forks
                                </div>
                            </div>
                            <div
                                class="rounded-lg p-4 text-center"
                                style={{
                                    backgroundColor: "var(--theme-welcomeBoxBg)",
                                    border: "1px solid var(--theme-border)",
                                }}
                            >
                                <div class="text-2xl font-bold" style={{ color: "var(--theme-primary)" }}>
                                    {githubData.stats.languages.length}
                                </div>
                                <div class="text-sm" style={{ color: "var(--theme-muted)" }}>
                                    Languages
                                </div>
                            </div>
                        </div>

                        {/* All Languages Section */}
                        <div class="mb-6">
                            <h2
                                class="text-lg font-semibold mb-3"
                                style={{ color: "var(--theme-primary)" }}
                            >
                                <span style={{ color: "var(--theme-muted)" }}>## </span>All
                                Languages Used
                            </h2>
                            <div
                                class="rounded-lg p-4"
                                style={{
                                    backgroundColor: "var(--theme-welcomeBoxBg)",
                                    border: "1px solid var(--theme-border)",
                                }}
                            >
                                <div class="flex flex-wrap gap-2">
                                    {
                                        githubData.stats.allLanguages.map(
                                            (language) => (
                                                <div
                                                    id={language}
                                                    class="flex items-center space-x-2 px-3 py-2 rounded-lg"
                                                    style={{
                                                        backgroundColor: "var(--theme-background)",
                                                        border: "1px solid var(--theme-border)",
                                                    }}
                                                >
                                                    <div
                                                        class="w-3 h-3 rounded-full"
                                                        style={{
                                                            backgroundColor:
                                                                getLanguageColor(
                                                                    language,
                                                                ),
                                                        }}
                                                    />
                                                    <span class="text-sm" style={{ color: "var(--theme-outputText)" }}>
                                                        {language}
                                                    </span>
                                                </div>
                                            ),
                                        )
                                    }
                                </div>
                                <div class="mt-3 text-xs" style={{ color: "var(--theme-muted)" }}>
                                    Total: {
                                        githubData.stats.allLanguages.length
                                    } languages across all repositories
                                </div>
                            </div>
                        </div>
                        <FeatureRepo featuredRepo={githubData.featured} />
                        <AllRepo allRepo={githubData.repositories} />
                    </div>
                    <ProjectsUpdateDate lastUpdated={githubData.lastUpdated} />
                </div>
                <Footer />
            </div>
        </div>
    </body>
</html>
